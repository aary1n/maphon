# Route large binaries through Git LFS to keep working-tree clones lean.
#
# `.mph` files are ignored everywhere except refs/ (see .gitignore); only
# the supervisor reference and the golden post-§5-gate model are tracked.
# Reference PDFs (papers, thesis drafts) live in the working tree and
# would otherwise bloat history significantly.

*.mph filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
refs/gate_runs/**/*.npz filter=lfs diff=lfs merge=lfs -text
refs/exports/**/*.npz filter=lfs diff=lfs merge=lfs -text

# Received raw data + derived artifacts are archived byte-for-byte
# (SHA-256-pinned in tests/test_provenance_df_spin_dt.py; the fit
# report must regenerate byte-identical). No EOL normalization.
refs/singh_2025_raw/** -text

# Cowley-Semple calibration archive: byte-for-byte, MANIFEST.sha256-pinned
# (calibration/integrity.py verifies in CI). Large binaries via LFS; the
# blanket -text keeps the CRLF manifest/eml/md and the derived CSV
# byte-stable through checkin/checkout.
calibration/data/raw/**/*.png filter=lfs diff=lfs merge=lfs -text
calibration/data/raw/**/*.eml filter=lfs diff=lfs merge=lfs -text
calibration/data/raw/**/*.docx filter=lfs diff=lfs merge=lfs -text
calibration/data/** -text
